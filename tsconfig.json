{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/hooks/*": ["./app/components/hooks/*"],
      "@/components/*": ["./app/components/*"],
      "@/constants/*": ["./app/constants/*"],
      "@/contexts/*": ["./app/contexts/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
